# Tradetron Automated Login Credentials
# Copy this file to .env and replace with your actual values
# cp .env.example .env

TRADETRON_EMAIL=your_email@example.com
TRADETRON_PASSWORD=your_secure_password

# Telegram Notification Settings (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broker Shortcodes for /report <code> command (optional)
# Format: BROKER_SHORTCODES=CODE1:Broker Name,CODE2:Broker Name
BROKER_SHORTCODES=FT:Flattrade,JR:Jainam Retail (XTS)
